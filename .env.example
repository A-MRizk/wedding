# Get a free access key at https://web3forms.com — submissions are emailed to the address you register there
VITE_WEB3FORMS_ACCESS_KEY=

# Optional: override background music (defaults to public/wedding-bg.mp3 — Frost Waltz, Kevin MacLeod)
# Use a direct link to an .mp3 or .ogg you have rights to. You cannot use a YouTube watch URL here:
# YouTube does not expose a stable audio file URL, and using ripped audio usually breaks their terms and copyright.
# VITE_WEDDING_MUSIC_URL=https://example.com/your-track.mp3
